# ============================================================================
# LexFlow Frontend — Environment Variables
# ============================================================================
# Copy this file to `.env.local` and fill in the values.
# REF: GOV-008 §3 (mandatory .env.example)
# REF: GOV-006 §11 (logging env vars)
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://lexflow_web:lexflow_web@localhost:5432/lexflow_main

# ── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# ── Trust Service (Backend Communication) ───────────────────────────────────
# REF: CON-001 §2 (shared secret auth)
INTERNAL_SERVICE_KEY=change-me-shared-secret
TRUST_SERVICE_URL=http://localhost:4000

# ── Logging (GOV-006) ──────────────────────────────────────────────────────
# Options: trace, debug, info, warn, error, fatal
LOG_LEVEL=warn
SERVICE_NAME=lexflow-web

# ── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Document Storage (GOV-008) ──────────────────────────────────────────
DOCUMENT_STORAGE_PATH=./uploads
